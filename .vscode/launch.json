{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Current Test File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}",
        "-v",
        "--no-cov",
        "--timeout=0"
      ],
      "justMyCode": false
    },
    {
      "name": "Debug Current Test (cursor on it)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}::${selectedText}",
        "-v",
        "--no-cov",
        "--timeout=0"
      ],
      "justMyCode": false
    },
    {
      "name": "Debug All Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/",
        "-v",
        "--no-cov",
        "--timeout=0"
      ],
      "justMyCode": false
    }
  ]
}
